    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet websiteData = { audit_result: null, website_url: null, _audit_available: false };\nlet igData      = { _ig_available: false, _fb_data: null };\nlet qualData    = { _qualitative_available: false };\n\nfor (const item of items) {\n  const d = item.json;\n  if (!d || !d.source) continue;\n  if (d.source === \"website_audit\") websiteData = d;\n  if (d.source === \"instagram\")     igData      = d;\n  if (d.source === \"qualitative\")   qualData    = d;\n}\n\nconst fbData = igData._fb_data || {};\n\nlet lead = {};\ntry { lead = $('Test Lead Data').first().json || {}; } catch(e) {}\n\n// Safely get audit sub-fields\nconst audit = websiteData.audit_result || {};\n\nreturn [{\n  json: {\n    // === IDENTITY ===\n    business_name: lead.business_name ?? qualData.business_name ?? null,\n    city:          lead.city          ?? null,\n    category:      lead.category      ?? fbData.category ?? null,\n    facebook_url:  lead.facebook_url  ?? null,\n    website_url:   lead.website_url   ?? websiteData.website_url ?? null,\n    place_id:      lead.place_id      ?? null,\n\n    // === DATA FLAGS (for evaluator null handling) ===\n    _data_flags: {\n      has_website:          !!(lead.website_url),\n      has_website_audit:    !!(websiteData._audit_available),\n      has_facebook:         !!(lead.facebook_url),\n      has_facebook_data:    !!(fbData._fb_available),\n      has_instagram_data:   !!(igData._ig_available),\n      has_qualitative_data: !!(qualData._qualitative_available)\n    },\n\n    // === QUALITATIVE (flat — matches prompt fields) ===\n    vibe_analysis:         qualData.vibe_analysis         ?? null,\n    key_offerings:         qualData.key_offerings         ?? null,\n    customer_pain_points:  qualData.customer_pain_points  ?? null,\n    digital_presence_gaps: qualData.digital_presence_gaps ?? null,\n    sentiment_summary:     qualData.sentiment_summary     ?? null,\n    confidence_score:      qualData.confidence_score      ?? null,\n\n    // === FACEBOOK (flat — matches prompt fields) ===\n    fb_followers:     fbData.followers     ?? null,\n    fb_likes:         fbData.likes         ?? null,\n    fb_email:         fbData.email         ?? null,\n    fb_phone:         fbData.phone         ?? null,\n    fb_rating:        fbData.rating        ?? null,\n    fb_review_count:  fbData.ratingCount   ?? null,\n    fb_address:       fbData.address       ?? null,\n    fb_services:      fbData.services      ?? null,\n    fb_ad_status:     fbData.ad_status     ?? null,\n    fb_creation_date: fbData.creation_date ?? null,\n    fb_category:      fbData.category      ?? null,\n\n    // === INSTAGRAM (flat — matches prompt fields) ===\n    ig_username:    igData.userName      ?? null,\n    ig_followers:   igData.followersCount ?? null,\n    ig_follows:     igData.followsCount  ?? null,\n    ig_profile_url: igData.userUrl       ?? null,\n\n    // === WEBSITE AUDIT (flat — matches prompt fields) ===\n    web_overall_score:       audit.overall_score       ?? null,\n    web_design_score:        audit.design_score        ?? null,\n    web_functionality_score: audit.functionality_score ?? null,\n    web_seo_score:           audit.seo_score           ?? null,\n    web_mobile_readiness:    audit.mobile_readiness    ?? null,\n    web_summary:             audit.summary             ?? null,\n    web_top_issues:          audit.top_issues          ?? null,\n    web_recommendation:      audit.recommendation      ?? null\n  }\n}];"
      },
