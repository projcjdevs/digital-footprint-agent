    {
      "parameters": {
        "jsCode": "// This runs after BOTH Parse Result and No Operation\n// Normalizes the output so Merge always gets clean data\n\nlet auditData = null;\n\ntry {\n  const item = $input.first();\n  const d = item.json;\n\n  // Check if we have real audit data\n  if (d && d.overall_score !== undefined && d.overall_score !== null) {\n    auditData = {\n      overall_score: d.overall_score ?? null,\n      design_score: d.design_score ?? null,\n      functionality_score: d.functionality_score ?? null,\n      seo_score: d.seo_score ?? null,\n      mobile_readiness: d.mobile_readiness ?? null,\n      summary: d.summary ?? null,\n      top_issues: d.top_issues ?? null,\n      recommendation: d.recommendation ?? null\n    };\n  }\n} catch(e) {\n  auditData = null;\n}\n\nreturn [{\n  json: {\n    source: \"website_audit\",\n    audit_result: auditData,\n    website_url: (() => {\n      try { return $('Test Lead Data').first().json.website_url ?? null; }\n      catch(e) { return null; }\n    })(),\n    _audit_available: auditData !== null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1024,
        -304
      ],
      "id": "52f24551-e94b-46c3-b8f8-d3777423b559",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "let fb = {};\n\ntry {\n  const item = $input.first();\n  const d = item.json;\n  // Check it's not an error object\n  if (d && !d.error && d.followers !== undefined) {\n    fb = d;\n  }\n} catch(e) {\n  fb = {};\n}\n\nconst hasData = Object.keys(fb).length > 0;\n\nreturn [{\n  json: {\n    source: \"facebook\",\n    followers: fb.followers ?? null,\n    likes: fb.likes ?? null,\n    phone: fb.phone ?? null,\n    email: fb.email ?? null,\n    rating: fb.rating ?? null,\n    ratingOverall: fb.ratingOverall ?? null,\n    ratingCount: fb.ratingCount ?? null,\n    address: fb.address ?? null,\n    services: fb.services ?? null,\n    ad_status: fb.ad_status ?? null,\n    creation_date: fb.creation_date ?? null,\n    category: fb.category ?? null,\n    _fb_available: hasData\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
